{
  "common": {
    "name": "daly-usb",
    "version": "0.2.3",
    "news": {
      "0.2.1": {
        "en": "remove prepare script so npm git installs use committed build output",
        "de": "prepare-Skript entfernt, damit npm-Git-Installationen das eingecheckte Build-Ergebnis verwenden"
      },
      "0.2.0": {
        "en": "hardware safety hardening, pack voltage ceiling from cell count",
        "de": "Hardware-Sicherheitshärtung, Packspannungsgrenze aus Zellanzahl"
      },
      "0.1.0": {
        "en": "initial release with full DALY UART protocol coverage",
        "de": "Erstveröffentlichung mit vollständiger DALY-UART-Protokollabdeckung"
      },
      "0.0.1": {
        "en": "initial release",
        "de": "Erstveröffentlichung"
      }
    },
    "title": "DALY BMS via USB-UART",
    "titleLang": {
      "en": "DALY BMS via USB-UART",
      "de": "DALY BMS über USB-UART"
    },
    "desc": {
      "en": "ioBroker adapter that talks to a DALY BMS over a USB-UART adapter.",
      "de": "ioBroker-Adapter zur Anbindung eines DALY BMS über USB-UART."
    },
    "authors": [
      "Paaaddy <noreply@example.com>"
    ],
    "keywords": [
      "daly",
      "bms",
      "battery",
      "usb",
      "uart"
    ],
    "license": "MIT",
    "platform": "Javascript/Node.js",
    "main": "build/main.js",
    "icon": "daly-usb.png",
    "enabled": true,
    "extIcon": "https://raw.githubusercontent.com/LeoTronick/DALY-USB/main/admin/daly-usb.png",
    "readme": "https://github.com/LeoTronick/DALY-USB/blob/main/README.md",
    "loglevel": "info",
    "mode": "daemon",
    "type": "energy",
    "compact": true,
    "connectionType": "local",
    "dataSource": "poll",
    "messagebox": false,
    "supportCustoms": false,
    "dependencies": [
      {
        "js-controller": ">=5.0.19"
      }
    ],
    "globalDependencies": [
      {
        "admin": ">=6.13.16"
      }
    ],
    "adminUI": {
      "config": "json"
    }
  },
  "native": {
    "serialPort": "",
    "baudRate": 9600,
    "hostAddress": 64,
    "pollIntervalMs": 5000,
    "requestTimeoutMs": 1000,
    "allowMosfetWrites": false
  },
  "objects": [],
  "instanceObjects": [
    {
      "_id": "info",
      "type": "channel",
      "common": {
        "name": "Information"
      },
      "native": {}
    },
    {
      "_id": "info.connection",
      "type": "state",
      "common": {
        "role": "indicator.connected",
        "name": "Device or service connected",
        "type": "boolean",
        "read": true,
        "write": false,
        "def": false
      },
      "native": {}
    }
  ]
}
